# Leave this unset to use the deterministic offline provider.
OPENAI_API_KEY=

DEEPREAD_PROVIDER=auto
DEEPREAD_OPENAI_MODEL=gpt-5.6-terra
DEEPREAD_EMBEDDING_MODEL=text-embedding-3-small
DEEPREAD_REASONING_EFFORT=low
DEEPREAD_OPENAI_STORE=false
DEEPREAD_MODEL_RERANK=true
DEEPREAD_MODEL_RERANK_TOP_K=8
DEEPREAD_MODEL_RERANK_RESCUE_PER_REQUIREMENT=1
DEEPREAD_MODEL_RERANK_MAX_CHARS=700
DEEPREAD_EVIDENCE_ASSESSMENT=true
DEEPREAD_EVIDENCE_SUPPORT_THRESHOLD=0.60
DEEPREAD_EMBEDDING_CACHE=.deepread/embeddings
DEEPREAD_MAX_REQUIREMENTS=4
DEEPREAD_RETRIEVAL_MODE=hybrid
DEEPREAD_READER_MODE=hierarchical
DEEPREAD_FLAT_TOP_K=5
DEEPREAD_EVIDENCE_WINDOW_SENTENCES=3
DEEPREAD_EVIDENCE_CANDIDATES_PER_REQUIREMENT=2
DEEPREAD_SUPERVISOR_MODE=bounded
DEEPREAD_ANSWER_POLICY=grounded
DEEPREAD_MAX_SEARCH_ROUNDS=2
DEEPREAD_RANDOM_SEED=0
DEEPREAD_TARGET_COVERAGE=0.50
DEEPREAD_DIVERSITY_WEIGHT=0.0

# Optional API-service paths.
DEEPREAD_CORPUS=data/sample_corpus
DEEPREAD_DB=.deepread/evidence.db

# Optional per-million-token rates used only for trace cost estimates.
DEEPREAD_MODEL_INPUT_COST_PER_MILLION=
DEEPREAD_MODEL_OUTPUT_COST_PER_MILLION=
DEEPREAD_EMBEDDING_COST_PER_MILLION=
